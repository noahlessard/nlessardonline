---
import BaseLayout from '../layouts/base.astro';
import BookListing from '../components/booklisting.astro';
import Link from '../components/link.astro'
import headshot from '../assets/headshot.jpg';
import Anticrawler from '../components/anticrawler.astro';
---


<BaseLayout>

    <BookListing 
    title="Hello!"
    image={headshot}
    >My name is Noah Lessard, welcome to my personal website. I recently graduated from UW-Madison with degrees in Computer Engineering as well as Computer Science. I've been running a virtual reality studio called <Link href="https://odachivr.art">OdachiVR</Link> for the last 2 years. I'm currently working at <Link href="https://www.ibm.com/us-en">IBM</Link>, working on their distributed file system technology. I am interested in automation, cybersecurity, embedded systems and virtual reality. When I'm not working with electronics, I like reading, gardening, hiking, retro games, and noodles.
    <br><br>
    Feel free to email me for any reason: <Anticrawler botMessage="noah (dot) lessard (at) me (dot) com" humanMessage="noah.lessard@me.com"></Anticrawler>
    <br><br>
    You can contact or connect with me on these sites: <Link href="https://github.com/noahlessard">Github</Link>, <Link href="https://www.linkedin.com/in/noah-lessard/">Linkedin</Link>, <Link href="https://www.goodreads.com/user/show/191788798">Goodreads</Link>.
    </BookListing>


    


</BaseLayout>